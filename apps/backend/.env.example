# Database Configuration
# Thay thế root:password và port tương ứng với MySQL của bạn
DATABASE_URL="mysql://root:12345678@localhost:3306/MYSQL80"

# JWT Configuration
JWT_ACCESS_SECRET="your_access_secret_change_me"
JWT_REFRESH_SECRET="your_refresh_secret_change_me"

# Groq API Configuration (for AI services)
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

# Cloudinary Configuration (for image uploading)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"

# Server Port
PORT=3000

# Frontend URL
FRONTEND_URL="http://localhost:8000"

